{
  "expo": {
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "app.tkbetter.pico.dev"
    },
    "assetBundlePatterns": ["**/*"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "0b4ed5dd-8139-4fce-96c3-5977720a896f"
      },
      "router": {}
    },
    "icon": "./assets/images/icon.png",
    "ios": {
      "bundleIdentifier": "app.tkbetter.pico.dev",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "name": "tkhwangPicoMobile",
    "newArchEnabled": true,
    "orientation": "portrait",
    "plugins": ["expo-router"],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "myapp",
    "slug": "tkhwang-pico-mobile",
    "splash": {
      "backgroundColor": "#ffffff",
      "image": "./assets/images/splash.png",
      "resizeMode": "contain"
    },
    "updates": {
      "url": "https://u.expo.dev/0b4ed5dd-8139-4fce-96c3-5977720a896f"
    },
    "userInterfaceStyle": "automatic",
    "version": "1.0.0",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png",
      "output": "static"
    }
  }
}
