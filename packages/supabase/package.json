{
  "name": "@tkhwang-pico/supabase",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./database": {
      "types": "./src/supabase/database.ts"
    },
    "./database.types": {
      "types": "./src/supabase/database.types.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "generate-types": "npx supabase gen types typescript --project-id hgkmrremnwapjdbebvqo --schema public > ./src/supabase/database.types.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tkhwang-pico/config-typescript": "*",
    "typescript": "^5.0.0"
  }
}
