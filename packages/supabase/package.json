{
  "devDependencies": {
    "@tkhwang-pico/config-eslint-prettier": "*",
    "@tkhwang-pico/config-typescript": "*",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./clients": {
      "default": "./dist/clients/index.js",
      "import": "./dist/clients/index.js",
      "types": "./dist/clients/index.d.ts"
    },
    "./repositories": {
      "default": "./dist/repositories/index.js",
      "import": "./dist/repositories/index.js",
      "types": "./dist/repositories/index.d.ts"
    },
    "./types": {
      "default": "./dist/types/index.js",
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "name": "@tkhwang-pico/supabase",
  "peerDependencies": {
    "@supabase/ssr": "^0.0.10",
    "@supabase/supabase-js": "^2.0.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate-types": "npx supabase gen types typescript --project-id hgkmrremnwapjdbebvqo --schema public > ./src/types/supabase-database.types.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "supabase:db:push": "supabase db push",
    "supabase:db:reset": "supabase db reset",
    "supabase:functions:deploy": "supabase functions deploy",
    "supabase:functions:serve": "supabase functions serve",
    "supabase:migration:list": "supabase migration list",
    "supabase:migration:new": "supabase migration new",
    "supabase:start": "supabase start",
    "supabase:status": "supabase status",
    "supabase:stop": "supabase stop",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "1.0.0"
}
